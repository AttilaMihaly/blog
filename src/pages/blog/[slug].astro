---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import GiscusComments from '../../components/GiscusComments.tsx';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: posts[i + 1] ?? null,
      nextPost: posts[i - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  dek={post.data.dek}
  kicker={post.data.kicker}
  tokens={post.data.tokens}
  readTime={post.data.readTime}
  issue={post.data.issue}
  prevPost={prevPost ? { id: prevPost.id, title: prevPost.data.title, issue: prevPost.data.issue } : undefined}
  nextPost={nextPost ? { id: nextPost.id, title: nextPost.data.title, issue: nextPost.data.issue } : undefined}
>
  <Content />
  <GiscusComments client:only="react" slot="comments" />
</BlogPost>
