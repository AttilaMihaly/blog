---
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  dek?: string;
  kicker?: string;
  tokens?: string;
  readTime?: string;
  issue?: string;
  prevPost?: { id: string; title: string; issue?: string };
  nextPost?: { id: string; title: string; issue?: string };
}

const { title, description, pubDate, dek, kicker, tokens, readTime, issue, prevPost, nextPost } = Astro.props;

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — The Invariable Difference</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Inter:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="dir-b">
  <Masthead currentPage="post" />

  <main class="post-main">
    <!-- Volume strap -->
    <div class="post-strap">
      <div class="eyebrow">{issue ? `Issue Nº ${issue}` : ''}</div>
      <div class="eyebrow" style="text-align: center;">{fmtDate(pubDate)}</div>
      <div class="eyebrow" style="text-align: right;">
        {readTime && <span>{readTime}</span>}
        {readTime && tokens && <span> · </span>}
        {tokens && (
          <span class="token-chip">
            <span class="num">{tokens}</span>
            <span class="lbl">tok</span>
          </span>
        )}
      </div>
    </div>
    <div class="rule"></div>

    <article class="post-article">
      <!-- Header -->
      <div class="eyebrow accent" style="text-align: center; margin-bottom: 24px;">
        {kicker ?? 'Post'}{issue ? ` · Nº ${issue}` : ''}
      </div>
      <h1 class="display post-title">{title}</h1>
      {dek && (
        <p class="display italic post-dek">{dek}</p>
      )}
      <div class="post-rule-center"></div>

      <!-- Body -->
      <div class="article-body">
        <slot />
      </div>

      <p class="post-end-mark mono">―</p>
    </article>

    <!-- Post navigation -->
    <div class="rule-soft" style="margin: 56px 0 22px;"></div>
    <div class="post-nav">
      {prevPost ? (
        <a href={`/blog/${prevPost.id}`} class="post-nav__link">
          ← {prevPost.issue ? `Nº ${prevPost.issue} · ` : ''}{prevPost.title}
        </a>
      ) : <span></span>}
      {nextPost && (
        <a href={`/blog/${nextPost.id}`} class="post-nav__link">
          {nextPost.issue ? `Nº ${nextPost.issue} · ` : ''}{nextPost.title} →
        </a>
      )}
    </div>

    <!-- Comments -->
    <section class="post-comments" aria-label="Comments">
      <slot name="comments" />
    </section>
  </main>

  <SiteFooter />
</body>
</html>

<style>
.post-main {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 64px 80px;
}
.post-strap {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 32px;
  align-items: center;
  padding: 20px 0 28px;
}
.post-article { padding-top: 56px; }
.post-title {
  font-size: 86px;
  line-height: 0.94;
  letter-spacing: -0.035em;
  text-align: center;
  margin-bottom: 22px;
  max-width: 900px;
  margin-left: auto;
  margin-right: auto;
}
.post-dek {
  font-size: 24px;
  line-height: 1.3;
  color: var(--ink-2);
  text-align: center;
  max-width: 720px;
  margin: 0 auto 36px;
}
.post-rule-center {
  width: 56px;
  height: 1px;
  background: var(--ink);
  margin: 0 auto 48px;
}
.post-end-mark {
  margin-top: 28px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--muted);
  letter-spacing: 0.04em;
}
.post-nav {
  font-family: var(--font-mono);
  font-size: 11.5px;
  color: var(--muted);
  max-width: 880px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
}
.post-nav__link {
  color: var(--muted);
  border-bottom: 1px solid var(--rule-soft);
  padding-bottom: 1px;
}
.post-nav__link:hover { color: var(--accent); border-bottom-color: var(--accent); }
.post-comments { margin-top: 64px; max-width: 660px; margin-left: auto; margin-right: auto; }
</style>
